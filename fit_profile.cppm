export constexpr FIT_EVENT FIT_EVENT_BATTERY_LOW{ 22 }; // marker
export constexpr FIT_EVENT FIT_EVENT_TIME_DURATION_ALERT{ 23 }; // Group 1. Start if enabled mid activity (not required at start of activity). Stop when duration is reached. stop_disable if disabled.
export constexpr FIT_EVENT FIT_EVENT_DISTANCE_DURATION_ALERT{ 24 }; // Group 1. Start if enabled mid activity (not required at start of activity). Stop when duration is reached. stop_disable if disabled.
